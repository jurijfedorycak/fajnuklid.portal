{
    "name": "fajnuklid/portal-api",
    "description": "Fajnuklid Portal REST API",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.6",
        "robmorgan/phinx": "^0.16"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "."
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
