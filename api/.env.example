# Application
APP_ENV=development
APP_DEBUG=true
# Optional. Absolute base URL of the API (scheme + host + API_PREFIX) used to build
# the stable proxy URLs the API hands to the FE. If left empty, the base URL is
# derived from the current request (Host + API_PREFIX, with scheme auto-detected).
# Set only when you want to pin one hostname regardless of how the API is reached.
APP_URL=

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=fajnuklid_portal
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=86400

# CORS
# Comma-separated allowlist. Add the deployed web origin (e.g. https://portal.fajnuklid.cz)
# in production. For the Capacitor mobile apps add https://localhost (unified
# scheme used by iOS/Android in capacitor.config.ts) and capacitor://localhost
# defensively for older Capacitor versions or scheme fallbacks.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://localhost,capacitor://localhost

# API path prefix (set to empty if API is served at root)
API_PREFIX=/api

# Admin status is stored in login_accounts.is_admin (managed via /admin/staff-contacts UI).

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# iDoklad
# Invoicing is split across several iDoklad accounts (separate legal entities) as
# a tax optimization; the portal reads from all of them and merges each customer's
# invoices. Declare the accounts with IDOKLAD_ACCOUNTS (a comma-separated list of
# stable numeric keys) plus a CLIENT_ID/CLIENT_SECRET pair per key, where the key
# is the env prefix. Keys are stable identifiers stored on every synced invoice —
# add new numbers as accounts are added, but do NOT renumber existing ones.
#   IDOKLAD_ACCOUNTS=1,2
#   IDOKLAD_1_CLIENT_ID=     IDOKLAD_1_CLIENT_SECRET=
#   IDOKLAD_2_CLIENT_ID=     IDOKLAD_2_CLIENT_SECRET=
# Optional per-account override: IDOKLAD_<KEY>_API_URL (defaults to IDOKLAD_API_URL).
IDOKLAD_ACCOUNTS=
# Legacy single-account fallback: if IDOKLAD_ACCOUNTS is empty, this pair is used
# as one account keyed 'default'.
IDOKLAD_CLIENT_ID=
IDOKLAD_CLIENT_SECRET=
IDOKLAD_API_URL=https://api.idoklad.cz/v3
# Shared secret required by POST /cron/idoklad-sync.
# Preferred: pass via X-Cron-Token header. Fallback: ?token= query param.
# Generate a strong random value (e.g. `openssl rand -hex 32`) and set it on both
# the deployed API and the scheduler that hits the URL nightly.
IDOKLAD_CRON_TOKEN=

# FreshQR. Read-only integration for attendance (docházka) data.
# Token is a long-lived bearer, prefixed with fqr_. Leave FRESHQR_API_KEY empty
# to disable the integration — AttendanceController will then report
# freshqrActive=false and the FE renders the onboarding state.
FRESHQR_API_URL=https://api.freshqr.online
FRESHQR_API_KEY=

# Cloudflare R2 Storage. The bucket must stay private — files are served exclusively
# through the HMAC-signed proxy URL (see StorageController::serveFile). Leave
# R2_PUBLIC_URL empty unless you explicitly want bucket contents to be world-readable.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# SMTP — leave SMTP_HOST blank (or default smtp.example.com) to fall back to PHP mail().
# SMTP_ENCRYPTION: tls (STARTTLS, port 587) | ssl (SMTPS, port 465) | none
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@fajnuklid.cz
SMTP_FROM_NAME=Fajnuklid Portal
