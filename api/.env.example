# Application
APP_ENV=development
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=fajnuklid_portal
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=86400

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API path prefix (set to empty if API is served at root)
API_PREFIX=/api

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@fajnuklid.cz

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# iDoklad
IDOKLAD_CLIENT_ID=
IDOKLAD_CLIENT_SECRET=
IDOKLAD_API_URL=https://api.idoklad.cz/v3

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@fajnuklid.cz
SMTP_FROM_NAME=Fajnuklid Portal
