RewriteEngine On
RewriteBase /

# Robots.txt - route to API for dynamic content
RewriteRule ^robots\.txt$ api/index.php [QSA,L]

# Redirect to API
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Handle Vue SPA routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!api/).*$ index.html [L]
