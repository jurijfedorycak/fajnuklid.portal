RewriteEngine On
RewriteBase /

DirectoryIndex index.html

# Force HTTPS and non-www (single redirect to canonical URL)
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# HSTS — tell browsers to always use HTTPS for this host
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Robots.txt - route to API for dynamic content
RewriteRule ^robots\.txt$ api/index.php [QSA,L]

# Redirect to API
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Handle Vue SPA routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!api/).*$ index.html [L]
